<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="@string/daily_habits"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_title">

        <!-- Water Intake -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/target_water"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_water"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:value="2500"
            android:valueFrom="1000"
            android:valueTo="5000"
            app:thumbColor="@color/cyan_glow"
            app:trackColorActive="@color/cyan_glow"
            app:trackColorInactive="#1affffff" />

        <!-- Sleep Schedule -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/target_sleep"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:value="8"
            android:valueFrom="4"
            android:valueTo="12"
            app:thumbColor="@color/cyan_glow"
            app:trackColorActive="@color/cyan_glow"
            app:trackColorInactive="#1affffff" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
