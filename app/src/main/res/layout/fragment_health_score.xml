<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_navy">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/glass_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/weekly_health_score"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">

                    <app.futured.donut.DonutProgressView
                        android:id="@+id/score_donut"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        app:donut_bgLineColor="#1affffff"
                        app:donut_strokeWidth="16dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_big_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dummy_score"
                        android:textColor="@color/text_primary"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@+id/score_donut"
                        app:layout_constraintEnd_toEndOf="@+id/score_donut"
                        app:layout_constraintStart_toStartOf="@+id/score_donut"
                        app:layout_constraintTop_toTopOf="@+id/score_donut" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/excellent"
                    android:textColor="@color/cyan_glow"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Trend Chart Placeholder -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/glass_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/score_trend_chart"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
