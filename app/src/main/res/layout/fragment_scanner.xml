<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_navy">

    <!-- Fake Camera Preview Placeholder -->
    <View
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#101010" />

    <!-- Scanner Frame -->
    <View
        android:id="@+id/scanner_frame"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_glass_card"
        android:alpha="0.3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scanning Beam Animation (Conceptual) -->
    <View
        android:id="@+id/scan_beam"
        android:layout_width="280dp"
        android:layout_height="2dp"
        android:background="@color/cyan_glow"
        app:layout_constraintStart_toStartOf="@+id/scanner_frame"
        app:layout_constraintEnd_toEndOf="@+id/scanner_frame"
        app:layout_constraintTop_toTopOf="@+id/scanner_frame" />

    <!-- HUD Overlay -->
    <TextView
        android:id="@+id/tv_scanner_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="@string/scanner_ready"
        android:textColor="@color/cyan_glow"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_capture"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="120dp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconSize="32dp"
        app:iconTint="@color/bg_deep_navy"
        app:backgroundTint="@color/cyan_glow"
        app:cornerRadius="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom Instruction Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/glass_card"
        app:cardCornerRadius="24dp"
        app:strokeColor="@color/glass_border"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/position_meal"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
