<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:title="My Health Data"
        app:titleTextColor="@color/text_white" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Name & Email -->
            <TextView
                android:id="@+id/tv_full_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name: Loading..."
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email: Loading..."
                android:textColor="@color/text_gray"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginBottom="16dp"/>

            <!-- Metrics -->
            <TextView
                android:id="@+id/tv_metrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Age: --\nHeight: --cm\nWeight: --kg\nBMI: --"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_dark"
                android:layout_marginBottom="16dp"/>

            <!-- Summaries -->
            <TextView
                android:id="@+id/tv_summaries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Water Intake: --L\nSleep Average: --h\nStress Level: --\nMood Summary: --"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
