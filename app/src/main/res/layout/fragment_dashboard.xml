<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/card_dark_secondary"
            app:cardCornerRadius="22dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="A"
                android:textColor="@color/accent_cyan"
                android:textSize="18sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@+id/card_avatar"
            app:layout_constraintStart_toEndOf="@+id/card_avatar"
            app:layout_constraintTop_toTopOf="@+id/card_avatar">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning,"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_dashboard_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_notifications"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/card_dark_secondary"
            app:cardCornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@color/text_white" />
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="100dp">

            <!-- 1. AI Insight Card (Improved) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ai_insight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iv_ai_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_nav_item_selected"
                        android:backgroundTint="#2019D3FF"
                        android:padding="12dp"
                        android:src="@drawable/ic_health_logo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/accent_cyan" />

                    <TextView
                        android:id="@+id/tv_ai_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="AI Health Insight"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/iv_ai_icon"
                        app:layout_constraintTop_toTopOf="@+id/iv_ai_icon" />

                    <TextView
                        android:id="@+id/tv_ai_recommendation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Your hydration improved 18% this week. Keep maintaining this level for optimal energy."
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/tv_ai_title"
                        app:layout_constraintTop_toBottomOf="@+id/tv_ai_title" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_ai_details"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="View Details"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@+id/tv_ai_recommendation"
                        app:layout_constraintTop_toBottomOf="@+id/tv_ai_recommendation" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Analytics Section 2x2 GRID (Improved) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/analytics_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/card_ai_insight">

                <!-- Calories -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_calories_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="24dp"
                    app:layout_constraintEnd_toStartOf="@+id/card_water_summary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calories" android:textColor="@color/text_gray" android:textSize="12sp" />
                        <TextView android:id="@+id/tv_calories_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="1240 / 2200" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/pb_calories_mini"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="12dp"
                            android:progress="56"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_calories_percent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="56% completed" android:textColor="@color/text_gray" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Water -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_water_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="24dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/card_calories_summary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Water" android:textColor="@color/text_gray" android:textSize="12sp" />
                        <TextView android:id="@+id/tv_water_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="2.5L / 3.0L" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/pb_water_mini"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="12dp"
                            android:progress="83"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_water_percent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="83% completed" android:textColor="@color/text_gray" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sleep -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_sleep_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="24dp"
                    app:layout_constraintEnd_toStartOf="@+id/card_stress_summary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/card_calories_summary"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sleep" android:textColor="@color/text_gray" android:textSize="12sp" />
                        <TextView android:id="@+id/tv_sleep_hours" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="7h 20m / 8h" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/pb_sleep_mini"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="12dp"
                            android:progress="92"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_sleep_percent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="92% completed" android:textColor="@color/text_gray" android:textSize="10sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stress -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_stress_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="24dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/card_sleep_summary"
                    app:layout_constraintTop_toBottomOf="@+id/card_water_summary"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stress"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_stress_level"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Low"
                            android:textColor="@color/text_white"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_stress_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Score 24"
                            android:textColor="@color/text_gray"
                            android:textSize="10sp" />
                        <ProgressBar
                            android:id="@+id/pb_stress_mini"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="4dp"
                            android:progress="24"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 3. Daily Goals Card (New) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_daily_goals_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toBottomOf="@+id/analytics_section"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Goal Progress"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Water Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Water" android:textColor="@color/text_white" android:textSize="13sp" />
                        <ProgressBar
                            android:id="@+id/pb_goal_water"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_weight="1"
                            android:progress="70"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_goal_water_percent" android:layout_width="40dp" android:layout_height="wrap_content" android:text="70%" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Calories Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Calories" android:textColor="@color/text_white" android:textSize="13sp" />
                        <ProgressBar
                            android:id="@+id/pb_goal_calories"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_weight="1"
                            android:progress="56"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_goal_calories_percent" android:layout_width="40dp" android:layout_height="wrap_content" android:text="56%" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Sleep Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Sleep" android:textColor="@color/text_white" android:textSize="13sp" />
                        <ProgressBar
                            android:id="@+id/pb_goal_sleep"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_weight="1"
                            android:progress="92"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_goal_sleep_percent" android:layout_width="40dp" android:layout_height="wrap_content" android:text="92%" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Steps Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Steps" android:textColor="@color/text_white" android:textSize="13sp" />
                        <ProgressBar
                            android:id="@+id/pb_goal_steps"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_weight="1"
                            android:progress="0"
                            android:progressTint="@color/accent_cyan"
                            android:progressBackgroundTint="@color/divider_dark" />
                        <TextView android:id="@+id/tv_goal_steps_percent" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0%" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Nutrient Breakdown"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_protein_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0g" android:textColor="@color/accent_cyan" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Protein" android:textColor="@color/text_gray" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_carbs_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0g" android:textColor="@color/accent_cyan" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carbs" android:textColor="@color/text_gray" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_fat_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0g" android:textColor="@color/accent_cyan" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fat" android:textColor="@color/text_gray" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Weekly Health Score Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_health_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toBottomOf="@+id/card_daily_goals_progress"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/donut_view"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly Health Score"
                            android:textColor="@color/text_white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Based on your daily goals"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_score_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_cyan_glow_pill"
                            android:backgroundTint="#2019D3FF"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp"
                            android:text="88 / 100"
                            android:textColor="@color/accent_cyan"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <app.futured.donut.DonutProgressView
                        android:id="@+id/donut_view"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:donut_bgLineColor="@color/divider_dark"
                        app:donut_gapAngle="0"
                        app:donut_gapWidth="0"
                        app:donut_strokeWidth="10dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Quick Actions -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_quick_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/card_health_score">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_scan_meal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="20dp"
                    app:layout_constraintEnd_toStartOf="@+id/card_log_water"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/accent_cyan" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Scan Meal"
                            android:textColor="@color/text_white"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_log_water"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/card_scan_meal"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_add"
                            app:tint="@color/accent_cyan" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Log Water"
                            android:textColor="@color/text_white"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 6. Predictive Health Analysis Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_predictive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toBottomOf="@+id/layout_quick_actions"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Predictive Health Analysis"
                            android:textColor="@color/text_white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="View your personalized risk assessments"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/text_gray" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
