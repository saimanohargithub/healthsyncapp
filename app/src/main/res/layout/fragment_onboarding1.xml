<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Background Glow -->
    <View
        android:id="@+id/v_glow"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:alpha="0.3"
        android:background="@drawable/bg_cyan_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-150dp"
        android:layout_marginTop="-100dp" />

    <!-- Hero Illustration Container -->
    <FrameLayout
        android:id="@+id/illustration_container"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:src="@drawable/bg_cyan_glow"
            android:alpha="0.5" />

        <ImageView
            android:id="@+id/iv_main"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_health_logo"
            app:tint="@color/accent_cyan" />

        <!-- Orbital Elements -->
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_cyan_glow"
            android:translationX="120dp"
            android:translationY="-100dp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_cyan_glow"
            android:translationX="-130dp"
            android:translationY="60dp" />

    </FrameLayout>

    <TextView
        android:id="@+id/tv_title"
        style="@style/PremiumHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="48dp"
        android:text="@string/ob_title_1"
        app:layout_constraintTop_toBottomOf="@+id/illustration_container" />

    <TextView
        android:id="@+id/tv_description"
        style="@style/PremiumSubHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="16dp"
        android:text="@string/ob_desc_1"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
