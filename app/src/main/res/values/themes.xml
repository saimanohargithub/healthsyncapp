<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.HealthSync" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cyan_glow</item>
        <item name="colorSecondary">@color/blue_glow</item>
        <item name="android:windowBackground">@color/bg_deep_navy</item>
        <item name="android:statusBarColor">@color/bg_deep_navy</item>
        <item name="android:navigationBarColor">@color/bg_deep_navy</item>
        <item name="colorSurface">@color/bg_deep_navy</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="NavLabelActive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="NavLabelInactive" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="NavLabelActiveLight" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="NavLabelInactiveLight" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="GreenButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/cyan_glow</item>
        <item name="android:textColor">@color/bg_deep_navy</item>
        <item name="cornerRadius">32dp</item>
    </style>

    <style name="PremiumHeader" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PremiumSubHeader" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="PremiumButton" parent="GreenButton" />
</resources>
