<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-feature android:name="android.hardware.sensor.stepcounter" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HealthSync">

        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="ocr,label" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.HealthSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.LoginActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.SignupActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.WizardActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.MealScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.MealScanningActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.MealResultActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.HealthDataActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.SettingsActivity"
            android:exported="false" />

        <activity
            android:name="com.example.healthsync.frontend.ui.activities.EditProfileActivity"
            android:exported="false" />

    </application>

</manifest>
